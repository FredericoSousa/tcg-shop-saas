generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Game {
  MAGIC
  POKEMON
  YUGIOH
}

enum Condition {
  NM
  SP
  MP
  HP
  D
}

model Tenant {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String  @unique
  name        String
  active      Boolean @default(true)
  brandColor  String?
  logoUrl     String?
  faviconUrl  String?
  description String?
  address     String?
  phone       String?
  email       String?
  instagram   String?
  whatsapp    String?
  facebook    String?
  twitter     String?

  inventory InventoryItem[]
  orders    Order[]
  users     User[]
  customers Customer[]

  @@map("tenants")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String
  passwordHash String
  role         UserRole @default(USER)
  tenantId     String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([username, tenantId])
  @@index([tenantId])
  @@map("users")
}

model CardTemplate {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  set          String
  imageUrl     String?
  backImageUrl String?
  game         Game
  metadata     Json?

  inventory InventoryItem[]

  @@index([name])
  @@map("card_templates")
}

model InventoryItem {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  cardTemplateId String    @db.Uuid
  price          Decimal
  quantity       Int       @default(0)
  condition      Condition
  language       String
  active         Boolean   @default(true)
  extras         String[]  @default([])

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  cardTemplate CardTemplate @relation(fields: [cardTemplateId], references: [id])
  orderItems   OrderItem[]

  @@index([tenantId])
  @@index([tenantId, quantity])
  @@index([cardTemplateId])
  @@map("inventory_items")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

model Order {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String      @db.Uuid
  customerId  String      @db.Uuid
  totalAmount Decimal
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime?   @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  customer Customer    @relation(fields: [customerId], references: [id])
  items    OrderItem[]

  @@index([tenantId])
  @@map("orders")
}

model OrderItem {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String  @db.Uuid
  inventoryItemId String  @db.Uuid
  quantity        Int
  priceAtPurchase Decimal

  order         Order         @relation(fields: [orderId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("order_items")
}

model Customer {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  phoneNumber String
  tenantId    String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  orders Order[]

  @@unique([phoneNumber, tenantId])
  @@index([tenantId])
  @@map("customers")
}

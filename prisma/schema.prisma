generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Game {
  MAGIC
  POKEMON
  YUGIOH
}

enum Condition {
  NM
  SP
  MP
  HP
  D
}

model Tenant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String   @unique
  name          String
  active        Boolean  @default(true)
  brandColor    String?  @map("brand_color")
  logoUrl       String?  @map("logo_url")
  faviconUrl    String?  @map("favicon_url")
  description   String?
  address       String?
  phone         String?
  email         String?
  instagram     String?
  whatsapp      String?
  facebook      String?
  twitter       String?
  /// Outbound webhook target for domain events (order.placed, etc.).
  /// Null disables delivery for the tenant.
  webhookUrl    String?  @map("webhook_url")
  /// HMAC-SHA256 signing secret. Rotated by re-saving via the admin
  /// settings endpoint. Stored as raw bytes; never logged.
  webhookSecret String?  @map("webhook_secret")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  inventory         InventoryItem[]
  orders            Order[]
  customers         Customer[]
  products          Product[]
  productCategories ProductCategory[]
  creditLedger      CustomerCreditLedger[]
  buylistItems      BuylistItem[]
  buylistProposals  BuylistProposal[]

  @@map("tenants")
}

model CardTemplate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  set          String
  imageUrl     String?  @map("image_url")
  backImageUrl String?  @map("back_image_url")
  game         Game
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  inventory            InventoryItem[]
  buylistItems         BuylistItem[]
  buylistProposalItems BuylistProposalItem[]

  @@index([name])
  @@index([name, set])
  @@map("card_templates")
}

model InventoryItem {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  cardTemplateId     String    @map("card_template_id") @db.Uuid
  price              Decimal   @db.Decimal(12, 2)
  quantity           Int       @default(0)
  condition          Condition
  language           String
  active             Boolean   @default(true)
  allowNegativeStock Boolean   @default(false) @map("allow_negative_stock")
  extras             String[]  @default([])
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  cardTemplate CardTemplate @relation(fields: [cardTemplateId], references: [id])
  orderItems   OrderItem[]

  @@index([tenantId])
  @@index([tenantId, quantity])
  @@index([cardTemplateId])
  @@map("inventory_items")
}

model ProductCategory {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  description     String?
  showOnEcommerce Boolean   @default(true) @map("show_on_ecommerce")
  tenantId        String    @map("tenant_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@index([tenantId])
  @@index([deletedAt])
  @@map("product_categories")
}

model Product {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  description        String?
  imageUrl           String?   @map("image_url")
  price              Decimal   @db.Decimal(12, 2)
  stock              Int       @default(0)
  categoryId         String    @map("category_id") @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  active             Boolean   @default(true)
  allowNegativeStock Boolean   @default(false) @map("allow_negative_stock")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  category   ProductCategory @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([name])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("products")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum OrderSource {
  POS
  ECOMMERCE
}

enum PaymentMethodType {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  TRANSFER
  STORE_CREDIT
  OTHER
}

model Order {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  customerId  String      @map("customer_id") @db.Uuid
  totalAmount Decimal     @map("total_amount") @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING)
  source      OrderSource @default(ECOMMERCE)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime?   @updatedAt @map("updated_at")
  friendlyId  String?     @map("friendly_id")
  staffNotes  String?     @map("staff_notes")

  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  customer     Customer               @relation(fields: [customerId], references: [id])
  items        OrderItem[]
  payments     OrderPayment[]
  creditLedger CustomerCreditLedger[]

  @@unique([tenantId, friendlyId])
  @@index([tenantId])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, source])
  @@index([tenantId, customerId, status])
  @@map("orders")
}

model OrderPayment {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String            @map("order_id") @db.Uuid
  method    PaymentMethodType
  amount    Decimal           @db.Decimal(12, 2)
  createdAt DateTime          @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_payments")
}

model OrderItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  inventoryItemId String?  @map("inventory_item_id") @db.Uuid
  productId       String?  @map("product_id") @db.Uuid
  quantity        Int
  priceAtPurchase Decimal  @map("price_at_purchase") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  order         Order          @relation(fields: [orderId], references: [id])
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  product       Product?       @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([inventoryItemId])
  @@index([productId])
  @@map("order_items")
}

model Customer {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  email         String?
  phoneNumber   String    @map("phone_number")
  creditBalance Decimal   @default(0) @map("credit_balance") @db.Decimal(12, 2)
  tenantId      String    @map("tenant_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  orders           Order[]
  ledger           CustomerCreditLedger[]
  buylistProposals BuylistProposal[]

  @@unique([phoneNumber, tenantId])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([deletedAt])
  @@map("customers")
}

enum CreditLedgerType {
  CREDIT
  DEBIT
}

enum CreditLedgerSource {
  MANUAL
  ORDER_PAYMENT
  ORDER_REFUND
  BUYLIST_PROPOSAL
}

model CustomerCreditLedger {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String             @map("tenant_id") @db.Uuid
  customerId  String             @map("customer_id") @db.Uuid
  orderId     String?            @map("order_id") @db.Uuid
  amount      Decimal            @db.Decimal(12, 2)
  type        CreditLedgerType
  source      CreditLedgerSource
  description String?
  createdAt   DateTime           @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])

  @@index([customerId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([customerId, createdAt])
  @@map("customer_credit_ledger")
}

enum BuylistStatus {
  PENDING
  RECEIVED
  APPROVED
  PAID
  CANCELLED
}

model BuylistItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  cardTemplateId String   @map("card_template_id") @db.Uuid
  priceCash      Decimal  @map("price_cash") @db.Decimal(12, 2)
  priceCredit    Decimal  @map("price_credit") @db.Decimal(12, 2)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cardTemplate CardTemplate @relation(fields: [cardTemplateId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("buylist_items")
}

model BuylistProposal {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  customerId  String        @map("customer_id") @db.Uuid
  status      BuylistStatus @default(PENDING)
  totalCash   Decimal       @map("total_cash") @db.Decimal(12, 2)
  totalCredit Decimal       @map("total_credit") @db.Decimal(12, 2)
  staffNotes  String?       @map("staff_notes")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    BuylistProposalItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([customerId])
  @@map("buylist_proposals")
}

/// Append-only outbox for at-least-once delivery of cross-aggregate
/// events. Producers INSERT into this table inside the same transaction
/// that mutates business state, so we never publish an event for a
/// transaction that didn't commit. A worker (cron / edge function)
/// drains rows where `processed_at IS NULL`, dispatches handlers, then
/// stamps `processed_at`.
model OutboxEvent {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String?   @map("tenant_id") @db.Uuid
  eventName       String    @map("event_name")
  payload         Json
  createdAt       DateTime  @default(now()) @map("created_at")
  processedAt     DateTime? @map("processed_at")
  attempts        Int       @default(0)
  lastError       String?   @map("last_error")
  /// Set when the event has exceeded MAX_ATTEMPTS and the worker has
  /// stopped retrying. Listed for ops via the DLQ admin endpoint.
  deadLetteredAt  DateTime? @map("dead_lettered_at")

  @@index([processedAt, createdAt])
  @@index([tenantId, eventName])
  @@index([deadLetteredAt])
  @@map("outbox_events")
}

enum AuditAction {
  DELETE
  UPDATE
  CREATE
  RESTORE
}

/// Append-only audit trail for sensitive operations (deletes, role
/// changes, credit adjustments). Never UPDATE or DELETE rows here —
/// retention/aging is handled by infra cron.
model AuditLog {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String      @map("tenant_id") @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  metadata   Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

model BuylistProposalItem {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buylistProposalId String    @map("buylist_proposal_id") @db.Uuid
  cardTemplateId    String    @map("card_template_id") @db.Uuid
  quantity          Int
  condition         Condition
  language          String
  priceCash         Decimal   @map("price_cash") @db.Decimal(12, 2)
  priceCredit       Decimal   @map("price_credit") @db.Decimal(12, 2)

  proposal     BuylistProposal @relation(fields: [buylistProposalId], references: [id], onDelete: Cascade)
  cardTemplate CardTemplate    @relation(fields: [cardTemplateId], references: [id], onDelete: Cascade)

  @@index([buylistProposalId])
  @@map("buylist_proposal_items")
}

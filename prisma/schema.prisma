generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Game {
  MAGIC
  POKEMON
  YUGIOH
}

enum Condition {
  NM
  SP
  MP
  HP
  D
}

model Tenant {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String  @unique
  name        String
  active      Boolean @default(true)
  brandColor  String? @map("brand_color")
  logoUrl     String? @map("logo_url")
  faviconUrl  String? @map("favicon_url")
  description String?
  address     String?
  phone       String?
  email       String?
  instagram   String?
  whatsapp    String?
  facebook    String?
  twitter     String?

  inventory InventoryItem[]
  orders    Order[]
  users     User[]
  customers Customer[]
  products  Product[]
  productCategories ProductCategory[]

  @@map("tenants")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String
  passwordHash String   @map("password_hash")
  role         UserRole @default(USER)
  tenantId     String   @map("tenant_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([username, tenantId])
  @@index([tenantId])
  @@map("users")
}

model CardTemplate {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  set          String
  imageUrl     String? @map("image_url")
  backImageUrl String? @map("back_image_url")
  game         Game
  metadata     Json?

  inventory InventoryItem[]

  @@index([name])
  @@map("card_templates")
}

model InventoryItem {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  cardTemplateId String    @map("card_template_id") @db.Uuid
  price          Decimal
  quantity       Int       @default(0)
  condition      Condition
  language       String
  active         Boolean   @default(true)
  extras         String[]  @default([])

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  cardTemplate CardTemplate @relation(fields: [cardTemplateId], references: [id])
  orderItems   OrderItem[]

  @@index([tenantId])
  @@index([tenantId, quantity])
  @@index([cardTemplateId])
  @@map("inventory_items")
}

model ProductCategory {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  description     String?
  showOnEcommerce Boolean @default(true) @map("show_on_ecommerce")
  tenantId        String  @map("tenant_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@index([tenantId])
  @@index([deletedAt])
  @@map("product_categories")
}

model Product {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  imageUrl    String? @map("image_url")
  price       Decimal
  stock       Int     @default(0)
  categoryId  String  @map("category_id") @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  active      Boolean @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  category   ProductCategory @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([name])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("products")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum OrderSource {
  POS
  ECOMMERCE
}

enum PaymentMethodType {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  TRANSFER
  OTHER
}

model Order {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  customerId  String         @map("customer_id") @db.Uuid
  totalAmount Decimal        @map("total_amount")
  status      OrderStatus    @default(PENDING)
  source      OrderSource    @default(ECOMMERCE)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime?      @updatedAt @map("updated_at")
  staffNotes  String?        @map("staff_notes")

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  customer Customer       @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  payments OrderPayment[]

  @@index([tenantId])
  @@map("orders")
}

model OrderPayment {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String            @map("order_id") @db.Uuid
  method    PaymentMethodType
  amount    Decimal
  createdAt DateTime          @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_payments")
}

model OrderItem {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String  @map("order_id") @db.Uuid
  inventoryItemId String? @map("inventory_item_id") @db.Uuid
  productId       String? @map("product_id") @db.Uuid
  quantity        Int
  priceAtPurchase Decimal @map("price_at_purchase")

  order         Order          @relation(fields: [orderId], references: [id])
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  product       Product?       @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Customer {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  email       String?
  phoneNumber String    @map("phone_number")
  tenantId    String    @map("tenant_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  orders Order[]

  @@unique([phoneNumber, tenantId])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("customers")
}
